# Copy this file to .env and fill in real values before running the app.
# See src/utils/env.ts for how each of these is read/validated.

# ============================================================
# REQUIRED — the app throws at boot if any of these are missing.
# ============================================================

# PostgreSQL connection string (Prisma).
DATABASE_URL="postgresql://user:password@localhost:5432/cdc_platform?schema=public"

# Secret used to sign/verify JWTs (jsonwebtoken). Use a long, random value in
# production — never reuse the local dev value below.
JWT_SECRET="replace-with-a-long-random-secret"

PORT=4000

# Azure Blob Storage — video/asset uploads (routes/upload.ts). No key or
# connection string: auth is via Managed Identity in Azure, or `az login`
# locally. e.g. "https://<account>.blob.core.windows.net" in production, or
# an Azurite emulator URL locally.
AZURE_STORAGE_ACCOUNT_URL="https://127.0.0.1:10000/devstoreaccount1"
AZURE_STORAGE_CONTAINER_NAME="videos"

# Shared secret an external scheduler (Azure Logic App, GitHub Actions cron,
# cron-job.org, etc.) must send as the X-Cron-Secret header when hitting
# POST /api/cron/auto-approve — see routes/cron.ts. Generate with e.g.
# `openssl rand -hex 24`.
CRON_SECRET="replace-with-a-random-secret"

# ============================================================
# OPTIONAL — the app boots fine without these; the dependent feature is
# disabled (or falls back to an Admin Panel-configured value) until set.
# ============================================================

# Public origin of the deployed frontend — used to build links sent in
# emails (email verification) and BOG payment redirect URLs. Defaults to
# http://localhost:3000 if unset.
FRONTEND_URL="http://localhost:3000"

# Public origin of THIS backend, reachable by Bank of Georgia's servers —
# used as the BOG webhook callback URL. Defaults to http://localhost:$PORT,
# which will NOT work with real BOG callbacks in production (BOG can't reach
# localhost) — must be a real public HTTPS URL there.
BACKEND_URL="http://localhost:4000"

# Google Cloud OAuth 2.0 Web application Client ID — enables "Sign in with
# Google" (POST /api/auth/google responds 501 until this is set). Must match
# the frontend's NEXT_PUBLIC_GOOGLE_CLIENT_ID (same Google Cloud OAuth
# client, from Google Cloud Console → APIs & Services → Credentials).
GOOGLE_CLIENT_ID=""

# Bank of Georgia (BOG) Payment API credentials (OAuth2 client_credentials —
# see services/bogPaymentService.ts). Leave blank to fall back to the Admin
# Panel's BOG settings (/admin/financials, SuperAdmin-only, stored in the
# bog_settings table) — real BOG-issued Client ID / Secret Key from your BOG
# merchant onboarding.
BOG_CLIENT_ID=""
BOG_SECRET_KEY=""

# Bunny Stream (video hosting/CDN for course lessons — see
# services/bunnyStreamService.ts). Leave blank to disable lesson video
# upload/playback (those routes respond 501 until set).
# - BUNNY_STREAM_API_KEY: Bunny Stream library API key (Bunny dashboard →
#   Stream → your library → API).
# - BUNNY_STREAM_LIBRARY_ID: numeric Video Library ID.
# - BUNNY_CDN_HOSTNAME: the library's pull-zone hostname, e.g.
#   "vz-xxxxxxxx-xxx.b-cdn.net" — used for thumbnail URLs only; playback uses
#   the fixed player.mediadelivery.net embed domain, which needs no config.
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_CDN_HOSTNAME=""

# Comma-separated emails that get auto-promoted to adminRole SUPER_ADMIN the
# moment they register, log in, or sign in with Google (see routes/auth.ts's
# maybePromoteSuperAdmin()). Empty by default — opt-in per deployment, not a
# code-level backdoor. Use sparingly; this is a permanent standing grant, not
# a one-off bootstrap like the SEED_SUPERADMIN_* vars below.
SUPER_ADMIN_EMAILS=""

# ============================================================
# SEED SCRIPT ONLY (prisma/seed.ts) — not read by the running app. Set these
# as one-off env vars when running `pnpm run db:seed`, not in the committed
# .env. Bootstraps the very first SuperAdmin account (registration is
# hardcoded to Student — see schemas/authSchemas.ts — so without this
# there's no way to ever get an admin account).
# ============================================================

# SEED_SUPERADMIN_EMAIL="admin@example.com"
# SEED_SUPERADMIN_PASSWORD="at-least-8-characters"
# SEED_SUPERADMIN_NAME="System Admin"                # optional, defaults shown
# SEED_ENTERPRISE_EMAIL="enterprise@example.com"      # optional — whole block skipped if unset
# SEED_ENTERPRISE_PASSWORD="at-least-8-characters"    # required only if SEED_ENTERPRISE_EMAIL is set
# SEED_ENTERPRISE_NAME="Enterprise Client"            # optional, defaults shown
