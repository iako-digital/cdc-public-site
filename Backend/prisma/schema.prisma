datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
// ============================================================
// ENUMS
// ============================================================

enum Role {
  Student
  Mentor
  SuperAdmin
  // Renamed from EnterpriseClient — same role (gig/vacancy posting client),
  // just a shorter name now that registration exposes it as a self-serve
  // choice ("💼 დამკვეთი") rather than an admin-only/B2B-only designation.
  Client
}

enum UserStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum GigBudgetType {
  fixed
  hourly
}

enum GigStatus {
  open
  assigned
  submitted
  completed
  cancelled
}

enum ApplicationStatus {
  submitted
  reviewed
  accepted
  rejected
}

enum EscrowStatus {
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  DISPUTED
}

enum WalletEntryType {
  ESCROW_RELEASE_CREDIT
  PAYOUT_DEBIT
  ADJUSTMENT
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
}

enum VacancyStatus {
  open
  closed
  filled
}

enum OrderStatus {
  Pending
  Approved
  Processing
  Completed
  Cancelled
}

enum ReviewType {
  CLIENT_TO_FREELANCER
  FREELANCER_TO_CLIENT
}

enum DirectOfferStatus {
  pending
  accepted
  declined
  withdrawn
}

// Internal admin-team permission tier — deliberately separate from `Role`
// (the marketplace role: Student/Mentor/SuperAdmin/EnterpriseClient). A user
// can have a marketplace role AND, independently, a seat on the admin team.
// SCREAMING_SNAKE_CASE on purpose, to keep it visually distinct from `Role`
// at every call site and avoid the two ever being confused for each other.
enum AdminRole {
  SUPER_ADMIN
  // Renamed from ADMIN — same tier (course CMS, gigs moderation, disputes),
  // just a name that matches the platform's public RBAC hierarchy naming.
  MANAGER
  MODERATOR
}

enum ListingModerationStatus {
  approved
  removed
}

enum BogPaymentPurpose {
  COURSE
  MENTORSHIP
  GIG_ESCROW_FUNDING
}

// Mirrors BOG's own order_status.key values (see GET /payments/v1/receipt/:id)
// down to PENDING/COMPLETED/FAILED/CANCELLED — collapsed to our 4 states
// rather than mirroring their full state machine (created/processing/
// refund_requested/refunded/etc), since refunds aren't implemented here.
enum BogPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  // Set only by an admin's manual "Refund & Access Revocation" action
  // (see routes/adminFinance.ts) — this is a record-keeping status, it does
  // NOT itself trigger a real bank refund through BOG; the admin still
  // processes the actual refund via BOG's own dashboard/support.
  REFUNDED
}

// ============================================================
// USER
// ============================================================

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  password        String
  name            String
  role            Role       @default(Student)
  status          UserStatus @default(PENDING_APPROVAL)
  rejectionReason String?
  earningsBalance Int        @default(0)
  // Denormalized rollup of `reviewsReceived`, recomputed on every new review —
  // avoids an AVG() aggregate query every time a rating needs to be displayed
  // (profile pages, gig/vacancy cards, etc).
  averageRating   Float?
  reviewCount     Int        @default(0)
  // Set only by a SuperAdmin (POST /api/admin/users/:id/verify-graduate) once
  // they've confirmed the user actually completed a CDC course — there is no
  // automated course-completion pipeline yet, so this is a manual gate.
  isVerifiedGraduate Boolean @default(false)
  // Soft-delete: set the moment the user confirms account deletion. The
  // account is deactivated immediately (blocked from logging in or taking
  // marketplace actions). 60 days later, the cleanup cron either hard-deletes
  // the row (if nothing references it) or anonymizes it in place (see
  // dataPurgedAt) when other users' financial/activity records depend on it.
  deletionRequestedAt DateTime?
  // Set when the 60-day cleanup cron anonymizes (rather than hard-deletes)
  // this row, so the cron doesn't keep re-processing it on every run.
  dataPurgedAt        DateTime?
  // Self-service email verification (separate from `status`'s admin-approval
  // gate — both must clear before protected actions, see requireApproved).
  // Set immediately for Google sign-ups (Google already verified the email).
  // Existing rows are backfilled to their createdAt at migration time so this
  // new gate doesn't retroactively lock out accounts that predate it.
  emailVerifiedAt                DateTime?
  emailVerificationToken         String?   @unique
  emailVerificationTokenExpires  DateTime?
  // Self-service password reset (POST /api/auth/forgot-password + /reset-password).
  passwordResetToken             String?   @unique
  passwordResetTokenExpires      DateTime?
  // Set for accounts created (or later linked) via Google Sign-In. Such
  // accounts get a random unusable password hash — there is no password-based
  // login path for them (see routes/auth.ts).
  googleId                       String?   @unique
  // Internal admin-team tier (see AdminRole) — null means "not on the admin
  // team." Independent of `role`; set only via the admin Team Management
  // panel (SUPER_ADMIN-only) or the one-off seed utility.
  adminRole       AdminRole?
  // Admin-initiated ban (distinct from `deletionRequestedAt`, which is
  // self-service account deletion). A banned user is blocked from logging in
  // and from every requireApproved-gated action, same enforcement points as
  // deletion, but reversible and admin-controlled.
  isBanned        Boolean    @default(false)
  bannedAt        DateTime?
  banReason       String?
  createdAt       DateTime   @default(now())

  postedGigs             Gig[]                @relation("PostedGigs")
  assignedGigs           Gig[]                @relation("AssignedGigs")
  gigApplications        GigApplication[]
  clientTransactions     GigTransaction[]     @relation("ClientTransactions")
  freelancerTransactions GigTransaction[]     @relation("FreelancerTransactions")
  walletEntries          WalletEntry[]
  postedVacancies        Vacancy[]
  vacancyApplications    VacancyApplication[]
  blogPosts              BlogPost[]
  reviewsGiven           Review[]             @relation("ReviewsGiven")
  reviewsReceived        Review[]             @relation("ReviewsReceived")
  sentDirectOffers       DirectOffer[]        @relation("SentDirectOffers")
  receivedDirectOffers   DirectOffer[]        @relation("ReceivedDirectOffers")
  sentMessages           Message[]            @relation("SentMessages")
  receivedMessages       Message[]            @relation("ReceivedMessages")
  paymentMethods         PaymentMethod[]
  bogPayments            BogPayment[]
  courseEnrollments      CourseEnrollment[]
  lessonProgress         LessonProgress[]
  courseCertificates     CourseCertificate[]
  examAttempts           ExamAttempt[]
  forumThreads           ForumThread[]
  forumComments          ForumComment[]
  forumThreadLikes       ForumThreadLike[]
  forumCommentLikes      ForumCommentLike[]
  disputesRaised         Dispute[]          @relation("DisputesRaised")
  disputesResolved       Dispute[]          @relation("DisputesResolved")
  payoutRequests         PayoutRequest[]    @relation("PayoutRequests")
  payoutRequestsReviewed PayoutRequest[]    @relation("PayoutRequestsReviewed")
  auditLogs              AuditLog[]

  @@map("users")
}

// ============================================================
// GIG
// ============================================================

model Gig {
  id                   String        @id @default(uuid())
  title                String
  description          String
  postedById           String
  postedBy             User          @relation("PostedGigs", fields: [postedById], references: [id], onDelete: Restrict)
  budgetType           GigBudgetType
  budgetAmount         Int
  currency             String        @db.Char(3)
  skillsRequired       String[]
  deadline             DateTime?
  status               GigStatus     @default(open)
  assignedFreelancerId String?
  assignedFreelancer   User?         @relation("AssignedGigs", fields: [assignedFreelancerId], references: [id], onDelete: SetNull)
  // Denormalized count of `applications`, incremented alongside each new
  // GigApplication — lets job cards show "N proposals" without a join/count
  // query on every listing fetch.
  applicationsCount    Int           @default(0)
  // Set when the freelancer submits delivered work (status -> submitted).
  // The 7-day auto-approve cron reads submittedAt to find overdue reviews.
  submittedAt          DateTime?
  deliveryComment      String?
  deliveryFiles        String[]      @default([])
  // Set when the assigned freelancer clicks "Request CDC Mentor Help" —
  // surfaces in the admin mentorship queue. Whether this is the student's
  // first-ever gig is computed at read time (their completed-gig count),
  // not stored, so it can never drift out of sync.
  mentorHelpRequestedAt DateTime?
  deliveryLinks        String[]      @default([])
  // Post-hoc moderation (not a pre-publish queue — listings go live
  // immediately on posting, same as before; a moderator can take one down
  // after the fact). Defaults to approved so existing behavior is unchanged.
  moderationStatus     ListingModerationStatus @default(approved)
  moderatedAt          DateTime?
  moderationReason     String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  applications GigApplication[]
  transaction  GigTransaction?
  reviews      Review[]
  directOffers DirectOffer[]
  disputes     Dispute[]

  @@index([status])
  @@index([status, skillsRequired])
  @@index([moderationStatus])
  @@map("gigs")
}

// ============================================================
// GIG APPLICATION
// ============================================================

model GigApplication {
  id           String            @id @default(uuid())
  gigId        String
  gig          Gig               @relation(fields: [gigId], references: [id], onDelete: Cascade)
  applicantId  String
  applicant    User              @relation(fields: [applicantId], references: [id], onDelete: Restrict)
  proposalNote String
  bidAmount    Int
  deliveryDays Int               @default(7)
  status       ApplicationStatus @default(submitted)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  transaction GigTransaction?

  @@unique([gigId, applicantId])
  @@index([status])
  @@map("gig_applications")
}

// ============================================================
// GIG TRANSACTION (Escrow ledger — capture record)
// ============================================================

model GigTransaction {
  id               String         @id @default(uuid())
  gigId            String         @unique
  gig              Gig            @relation(fields: [gigId], references: [id], onDelete: Restrict)
  gigApplicationId String         @unique
  gigApplication   GigApplication @relation(fields: [gigApplicationId], references: [id], onDelete: Restrict)
  clientId         String
  client           User           @relation("ClientTransactions", fields: [clientId], references: [id], onDelete: Restrict)
  freelancerId     String
  freelancer       User           @relation("FreelancerTransactions", fields: [freelancerId], references: [id], onDelete: Restrict)
  grossAmount      Int
  commissionRate   Float
  commissionAmount Int
  netAmount        Int
  currency         String         @db.Char(3)
  status           EscrowStatus   @default(HELD_IN_ESCROW)
  providerRef      String         @unique
  capturedAt       DateTime
  releasedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  walletEntries WalletEntry[]

  @@index([status])
  @@map("gig_transactions")
}

// ============================================================
// WALLET ENTRY (Escrow ledger — append-only, immutable)
// ============================================================

model WalletEntry {
  id                      String          @id @default(uuid())
  userId                  String
  user                    User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  type                    WalletEntryType
  amount                  Int
  relatedGigTransactionId String?
  relatedGigTransaction   GigTransaction? @relation(fields: [relatedGigTransactionId], references: [id], onDelete: SetNull)
  balanceAfter            Int
  createdAt               DateTime        @default(now())

  @@index([userId])
  @@map("wallet_entries")
}

// ============================================================
// VACANCY
// ============================================================

model Vacancy {
  id                  String         @id @default(uuid())
  title               String
  description         String
  postedById          String
  postedBy            User           @relation(fields: [postedById], references: [id], onDelete: Restrict)
  employmentType      EmploymentType
  location            String
  skillsRequired      String[]
  salaryMin           Int?
  salaryMax           Int?
  currency            String?        @db.Char(3)
  applicationDeadline DateTime?
  status              VacancyStatus  @default(open)
  moderationStatus     ListingModerationStatus @default(approved)
  moderatedAt          DateTime?
  moderationReason     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  applications VacancyApplication[]

  @@index([status])
  @@index([moderationStatus])
  @@map("vacancies")
}

// ============================================================
// VACANCY APPLICATION
// ============================================================

model VacancyApplication {
  id          String            @id @default(uuid())
  vacancyId   String
  vacancy     Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User              @relation(fields: [applicantId], references: [id], onDelete: Restrict)
  coverNote   String
  status      ApplicationStatus @default(submitted)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([vacancyId, applicantId])
  @@index([status])
  @@map("vacancy_applications")
}

// ============================================================
// COURSE
// ============================================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  // Legacy flat lesson blob — predates CourseSection/Lesson below and is left
  // as-is for backward compat with the existing admin course-create form
  // (lib/api.ts's CoursePayload). The Udemy-style /learn player reads the
  // relational `sections` instead.
  lessons      Json
  // Minor units (tetri) — matches this codebase's Int-money convention
  // everywhere else (Gig.budgetAmount, BogPayment.amount, etc.). The user-
  // facing "sale price" is never stored — see services/coursePricing.ts's
  // getCurrentPrice(), computed at read time so an expired discountEndDate
  // reverts to originalPrice automatically with no cron/cleanup needed.
  originalPrice   Int
  discountPercent Int?
  discountEndDate DateTime?
  isOnSale        Boolean  @default(false)
  published    Boolean @default(false)
  mentorName   String?
  mentorTitle  String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]             @relation("OrderCourses")
  enrollments  CourseEnrollment[]
  sections     CourseSection[]
  certificates CourseCertificate[]
  // One AI-generated certification exam per course, if configured by an
  // admin — courses without one keep the old "100% lessons" certificate gate
  // (see routes/courses.ts's GET /:id/certificate).
  exam         Exam?

  @@map("courses")
}

// ============================================================
// LMS — relational curriculum (sections -> lessons), per-user lesson
// progress, and issued certificates. Coexists with the legacy Course.lessons
// Json blob above.
// ============================================================

model CourseSection {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons Lesson[]

  @@index([courseId])
  @@map("course_sections")
}

model Lesson {
  id              String   @id @default(uuid())
  sectionId       String
  section         CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title           String
  durationSeconds Int      @default(0)
  // Bunny Stream video GUID (services/bunnyStreamService.ts) — null until an
  // admin uploads a video for this lesson.
  bunnyVideoId    String?
  resources       String[] @default([])
  order           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress LessonProgress[]

  @@index([sectionId])
  @@map("lessons")
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// One row per (user, course) once a certificate has been generated — makes
// re-downloads idempotent (same verification code every time) rather than
// minting a new "unique" code on every click.
model CourseCertificate {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  courseId         String
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  verificationCode String   @unique
  issuedAt         DateTime @default(now())

  @@unique([userId, courseId])
  @@map("course_certificates")
}

// ============================================================
// AI EXAM & CERTIFICATION GATE — one Exam per course (admin-configured);
// questions are generated on demand by services/aiExamService.ts, not
// stored ahead of time. Each attempt is scored server-side and recorded
// here; GET /:id/certificate requires a `passed` ExamAttempt to exist for
// courses that have an Exam configured.
// ============================================================

model Exam {
  id       String @id @default(uuid())
  courseId String @unique
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Percentage (0-100) required to pass, e.g. 95.
  passingScore Int @default(95)
  // Minimum wait between a failed attempt and the next one.
  cooldownHours Int @default(24)
  questionCount Int @default(10)
  // Free-text steer for the AI question generator (topics to emphasize,
  // difficulty, tone) — appended to the base prompt in aiExamService.ts.
  aiPromptContext String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts ExamAttempt[]

  @@map("exams")
}

model ExamAttempt {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  score       Float
  passed      Boolean
  // Snapshot of the questions this attempt was scored against (including
  // correct answers + explanations) — lets a student review what they got
  // wrong without trusting the client to have kept an honest copy.
  questions   Json
  weakTopics  String[] @default([])
  completedAt DateTime @default(now())

  @@index([userId, examId])
  @@index([examId])
  @@map("exam_attempts")
}

// ============================================================
// COURSE ENROLLMENT (individual purchase access — separate from `Order`,
// which is the pre-existing B2B bulk-seat model; this is one student buying
// access to one course via BOG checkout)
// ============================================================

model CourseEnrollment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  grantedAt  DateTime @default(now())

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

// ============================================================
// ORDER
// ============================================================

model Order {
  id           String      @id @default(uuid())
  enterprise   String
  contactEmail String
  courses      Course[]    @relation("OrderCourses")
  quantity     Int
  totalPrice   Int
  status       OrderStatus @default(Pending)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@map("orders")
}

// ============================================================
// BLOG POST
// ============================================================

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  content     String
  imageUrl    String?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@map("blog_posts")
}

// ============================================================
// REVIEW (two-way, Upwork-style — one per participant per completed gig)
// ============================================================

model Review {
  id         String     @id @default(uuid())
  gigId      String
  gig        Gig        @relation(fields: [gigId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User       @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Restrict)
  revieweeId String
  reviewee   User       @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Restrict)
  rating     Int
  comment    String
  type       ReviewType
  createdAt  DateTime   @default(now())

  // One review per (gig, reviewer) — a participant can only review a given
  // gig once, which is also how "already reviewed" is enforced server-side.
  @@unique([gigId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

// ============================================================
// DIRECT OFFER (client-initiated outreach to a specific freelancer —
// either attached to one of the client's own open gigs, or a standalone
// quick custom offer with no gig behind it yet)
// ============================================================

model DirectOffer {
  id           String            @id @default(uuid())
  clientId     String
  client       User              @relation("SentDirectOffers", fields: [clientId], references: [id], onDelete: Restrict)
  freelancerId String
  freelancer   User              @relation("ReceivedDirectOffers", fields: [freelancerId], references: [id], onDelete: Restrict)
  gigId        String?
  gig          Gig?              @relation(fields: [gigId], references: [id], onDelete: SetNull)
  title        String
  description  String
  budgetAmount Int
  currency     String            @db.Char(3)
  message      String
  status       DirectOfferStatus @default(pending)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([freelancerId])
  @@index([clientId])
  @@map("direct_offers")
}

// ============================================================
// MESSAGE (direct 1:1 chat between two users — content is sanitized with
// sanitizeChatMessage server-side BEFORE it ever reaches this table, so
// what's stored is already safe to display as-is)
// ============================================================

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Restrict)
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Restrict)
  content     String
  wasFiltered Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId])
  @@index([recipientId, senderId])
  @@map("messages")
}

// ============================================================
// PAYMENT METHOD (view/delete only — there is no payment-processor
// integration in this app yet, so nothing can create one through the API;
// existing rows would come from a future Stripe/etc. integration or manual
// seeding, same as this endpoint's original frontend scaffold assumed)
// ============================================================

model PaymentMethod {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  processorToken String
  brand          String
  last4          String
  expiryMonth    Int
  expiryYear     Int
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("payment_methods")
}

// ============================================================
// BOG SETTINGS (Bank of Georgia payment gateway config — SUPER_ADMIN only)
//
// There is no real BOG merchant integration wired up anywhere in this app —
// no payment gateway has ever called out to BOG. This model is a config
// store the admin panel can read/write; secretKey/webhookSecret are never
// echoed back in full once set (masked, same principle as never returning a
// password hash). A single row is used as an app-wide singleton — the
// service layer enforces that, not the schema.
// ============================================================

model BogSettings {
  id             String   @id @default(uuid())
  // OAuth2 client_credentials — matches BOG's real Online Payment API
  // (POST https://oauth2.bog.ge/auth/realms/bog/protocol/openid-connect/token,
  // Basic auth of clientId:secretKey). Renamed from merchantId/publicKey/
  // webhookSecret (this session's earlier guess before the real API contract
  // was confirmed) — BOG doesn't take a separate "merchant id" or "our public
  // key," and callback authenticity is verified against BOG's own published
  // RSA public key (hardcoded in bogPaymentService.ts), not a shared secret.
  clientId       String?
  secretKey      String?
  isLiveMode     Boolean  @default(false)
  updatedByEmail String?
  updatedAt      DateTime @updatedAt

  @@map("bog_settings")
}

// ============================================================
// BOG PAYMENT (one row per BOG order, across all three checkout flows —
// purpose + referenceId is a lightweight polymorphic pointer rather than
// three near-identical tables, since the payment lifecycle itself — create
// order, await callback, mark completed/failed — is identical regardless of
// what's being paid for)
// ============================================================

model BogPayment {
  id          String            @id @default(uuid())
  bogOrderId  String            @unique
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  purpose     BogPaymentPurpose
  // COURSE -> Course.id, MENTORSHIP -> free-text package label (no
  // mentorship/booking model exists yet), GIG_ESCROW_FUNDING -> Gig.id
  referenceId String
  amount      Int               // minor units
  currency    String            @db.Char(3)
  status      BogPaymentStatus  @default(PENDING)
  redirectUrl String?
  // Last callback payload received from BOG, kept for audit/debugging —
  // never trusted as the source of truth without signature verification.
  rawCallback Json?
  createdAt   DateTime          @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([purpose, referenceId])
  @@map("bog_payments")
}

// ============================================================
// FORUM — categories, threads, comments, likes. New threads are
// pre-moderated (PENDING until a Mentor/SuperAdmin approves them);
// comments are not, matching the admin brief's "pending POSTS require
// approval" scope. Pin/lock are separate moderator actions available on
// already-approved threads.
// ============================================================

enum ForumModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ForumCategory {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())

  threads ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id         String        @id @default(uuid())
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  title      String
  content    String

  moderationStatus ForumModerationStatus @default(PENDING)
  moderationReason String?
  moderatedAt      DateTime?
  isPinned         Boolean               @default(false)
  isLocked         Boolean               @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments ForumComment[]
  likes    ForumThreadLike[]

  @@index([categoryId])
  @@index([moderationStatus])
  @@map("forum_threads")
}

model ForumComment {
  id       String      @id @default(uuid())
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User        @relation(fields: [authorId], references: [id], onDelete: Restrict)
  content  String

  createdAt DateTime @default(now())

  likes ForumCommentLike[]

  @@index([threadId])
  @@map("forum_comments")
}

model ForumThreadLike {
  id       String      @id @default(uuid())
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("forum_thread_likes")
}

model ForumCommentLike {
  id        String       @id @default(uuid())
  commentId String
  comment   ForumComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("forum_comment_likes")
}

// ============================================================
// DISPUTES — opened by either party on a gig when work is incomplete or
// disputed. Resolution is a manual admin action (refund the client or
// release payout to the freelancer); no automatic money movement here,
// same posture as PayoutRequest below.
// ============================================================

enum DisputeStatus {
  OPEN
  RESOLVED_REFUND
  RESOLVED_PAYOUT
  DISMISSED
}

model Dispute {
  id     String @id @default(uuid())
  gigId  String
  gig    Gig    @relation(fields: [gigId], references: [id], onDelete: Cascade)

  raisedById String
  raisedBy   User   @relation("DisputesRaised", fields: [raisedById], references: [id], onDelete: Restrict)
  reason     String

  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?
  resolvedBy   User?         @relation("DisputesResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([gigId])
  @@index([status])
  @@map("disputes")
}

// ============================================================
// PAYOUT REQUESTS — a student's ask to withdraw their earningsBalance to a
// bank account. This only tracks the request/approval workflow; approving
// one debits earningsBalance and writes a WalletEntry(PAYOUT_DEBIT), same
// as every other wallet mutation, but the actual bank transfer happens
// manually outside the platform (an admin wires the money via BOG's own
// dashboard/banking), same posture as the BOG merchant credentials already
// being admin-managed rather than fully automated end-to-end.
// ============================================================

enum PayoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model PayoutRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("PayoutRequests", fields: [userId], references: [id], onDelete: Restrict)

  amount Int    // minor units
  iban   String

  status       PayoutRequestStatus @default(PENDING)
  adminNote    String?
  reviewedById String?
  reviewedBy   User?               @relation("PayoutRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@map("payout_requests")
}

// ============================================================
// AUDIT LOG — append-only record of sensitive admin actions (bans, role
// changes, payout approvals, dispute resolutions, forum moderation, manual
// course grants, refunds). Written by services/auditLogService.ts.
// ============================================================

model AuditLog {
  id String @id @default(uuid())

  action        String // e.g. "user.ban", "payout.approve", "dispute.resolve"
  targetType    String // e.g. "User", "PayoutRequest", "ForumThread"
  targetId      String
  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id], onDelete: Restrict)
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([performedById])
  @@map("audit_logs")
}