# Copy this file to .env.local and fill in real values before running the app.
# Only variables prefixed NEXT_PUBLIC_ are exposed to the browser; everything
# else here is read server-side only (in pages/api/* routes).

# Base URL of the backend API. Defaults to http://localhost:4000/api if unset
# (see src/services/apiClient.ts) — set to the real deployed backend origin
# (e.g. https://api.example.com/api) in production.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Google Cloud OAuth 2.0 Web application Client ID — enables the "Sign in
# with Google" button in AuthModal.tsx. Must be the SAME Google Cloud OAuth
# client as Backend/.env's GOOGLE_CLIENT_ID. Leave blank to leave the Google
# button disabled/hidden.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Gemini API key for the homepage AI Career Assistant chatbot
# (pages/api/chat.ts / lib/gemini.ts, server-side only — deliberately NOT
# NEXT_PUBLIC_). Leave blank and the chat endpoint responds with a friendly
# "not configured" message; the rest of the site is unaffected. Same key as
# Backend/.env's GEMINI_API_KEY.
GEMINI_API_KEY=

# NOTE: Bunny Stream credentials (BUNNY_STREAM_API_KEY,
# BUNNY_STREAM_LIBRARY_ID, BUNNY_CDN_HOSTNAME) are NOT used anywhere in this
# Frontend project — lesson video upload/playback is entirely backend-driven
# (see Backend/.env.example). Don't set them here.
